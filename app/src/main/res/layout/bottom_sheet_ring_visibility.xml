<?xml version="1.0" encoding="utf-8"?>
<!--
    Task 5.2: Ring visibility BottomSheetDialog layout.
    TSPEC §6.4 — vertical LinearLayout with 6 toggle rows, one per ring.
    Each row contains a Switch (left) and a TextView label (right).
    FSPEC Flow 5: switch states reflect current ringVisibility; toggles update immediately.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="16dp"
    android:background="#2C0E0E">

    <!-- Sheet title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ring_visibility_sheet_title"
        android:textColor="#C9A84C"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingBottom="8dp"
        android:gravity="center" />

    <!-- Ring 1 — 天池 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="8dp">

        <Switch
            android:id="@+id/switchRing1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/ring1_label" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/ring1_label"
            android:textColor="#E8C97A"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Ring 2 — 後天八卦 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="8dp">

        <Switch
            android:id="@+id/switchRing2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/ring2_label" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/ring2_label"
            android:textColor="#E8C97A"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Ring 3 — 十二地支 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="8dp">

        <Switch
            android:id="@+id/switchRing3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/ring3_label" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/ring3_label"
            android:textColor="#E8C97A"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Ring 4 — 二十四山 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="8dp">

        <Switch
            android:id="@+id/switchRing4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/ring4_label" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/ring4_label"
            android:textColor="#E8C97A"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Ring 5 — 六十分金 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="8dp">

        <Switch
            android:id="@+id/switchRing5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/ring5_label" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/ring5_label"
            android:textColor="#E8C97A"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Done button -->
    <Button
        android:id="@+id/btnRingVisibilityDone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/ring_visibility_done"
        android:backgroundTint="#C9A84C"
        android:textColor="#2C0E0E" />

</LinearLayout>
