<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Search bar (GONE in State A: zero records with no active search) -->
    <SearchView
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:iconifiedByDefault="false"
        android:queryHint="Search bearings…"
        android:visibility="gone" />

    <!-- Age-based recalibration banner (GONE by default) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/banner_age_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorPrimaryContainer"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/banner_age_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/banner_age_close"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/banner_age_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Dismiss age banner"
            android:background="?attr/selectableItemBackgroundBorderless"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Drift-based recalibration banner (GONE by default) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/banner_drift_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSecondaryContainer"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/banner_drift_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/banner_drift_close"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/banner_drift_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Dismiss drift banner"
            android:background="?attr/selectableItemBackgroundBorderless"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RecyclerView (GONE when empty state is shown) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- Empty state: zero records (shown when no records exist and no search active) -->
    <!-- REQ-CAPTURE-03 §5.1 Scenario A2: illustration + message both required -->
    <LinearLayout
        android:id="@+id/empty_state_no_records"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="visible">

        <ImageView
            android:id="@+id/empty_state_illustration"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_empty_history"
            android:contentDescription="@string/empty_illustration_desc"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/empty_state_no_records_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/empty_no_bearings"
            android:gravity="center"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Empty state: no search results (shown when search active but no matches) -->
    <TextView
        android:id="@+id/empty_state_no_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="@string/empty_no_results"
        android:gravity="center"
        android:padding="24dp"
        android:textSize="16sp"
        android:visibility="gone" />

</LinearLayout>
